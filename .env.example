# --- Database ---
DATABASE_URL=postgresql+asyncpg://nova_user:changeme@db:5432/nova_db

# --- Redis (rate limiting / caching) ---
REDIS_URL=redis://redis:6379

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Embedding encryption (AES-256 / Fernet) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EMBEDDING_ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# --- Scene description (VLM) ---
USE_LOCAL_VLM=true
OPENAI_API_KEY=
VLM_MODEL_NAME=Salesforce/blip2-opt-2.7b

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60
# Use "memory://" for single-instance local dev. Set to the same value as
# REDIS_URL in any multi-worker/multi-instance deployment so the rate
# limit is enforced globally rather than per-worker.
RATE_LIMIT_STORAGE_URI=redis://redis:6379

# --- Model registry ---
MODEL_STORAGE_PATH=/app/models

# --- Postgres container (docker-compose) ---
POSTGRES_PASSWORD=changeme

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=*
